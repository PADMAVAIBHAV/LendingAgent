# ═══════════════════════════════════════════════════════════════
#  AgentLend AI — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Application ────────────────────────────────────────────────
APP_NAME=AgentLend AI
DEBUG=false

# ── PostgreSQL Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentlend

# ── Google Gemini LLM ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── WDK by Tether ─────────────────────────────────────────────
WDK_API_KEY=
WDK_BASE_URL=https://api.wdk.tether.to/v1

# ── Ethereum Sepolia ──────────────────────────────────────────
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETHERSCAN_API_KEY=your-etherscan-api-key-here
CHAIN_ID=11155111

# ── Treasury Wallet ───────────────────────────────────────────
TREASURY_WALLET_ADDRESS=0xYourTreasuryWalletAddress
TREASURY_PRIVATE_KEY=your-treasury-private-key-hex

# ── ERC-20 Token (USDT-style on Sepolia) ─────────────────────
TOKEN_CONTRACT_ADDRESS=0xYourERC20TokenContractAddress
TOKEN_DECIMALS=6

# ── Autonomous Agent Timing ──────────────────────────────────
AGENT_LOOP_INTERVAL_SECONDS=120
REPAYMENT_MONITOR_INTERVAL_SECONDS=60

# ── Loan Limits ──────────────────────────────────────────────
MAX_LOAN_AMOUNT=1000.0
MIN_LOAN_AMOUNT=10.0
DEFAULT_LOAN_DURATION_DAYS=30
